{
  "_comment": "DeepSpeed ZeRO-2 config for OpenVLA-OFT on 8x H100. ZeRO-2 shards optimizer states and gradients (not parameters), so the full model is on each GPU — eval rollouts work without gather calls. ZeRO-3 would halve memory further but requires model.module unwrapping before inference, which complicates mid-training evals.",

  "zero_optimization": {
    "stage": 2,
    "allgather_partitions": true,
    "allgather_bucket_size": 500000000,
    "overlap_comm": true,
    "reduce_scatter": true,
    "reduce_bucket_size": 500000000,
    "contiguous_gradients": true,
    "cpu_offload": false
  },

  "bf16": {
    "enabled": true
  },
  "fp16": {
    "enabled": false
  },

  "gradient_clipping": 1.0,

  "train_micro_batch_size_per_gpu": "auto",
  "gradient_accumulation_steps": "auto",
  "train_batch_size": "auto",

  "optimizer": {
    "type": "AdamW",
    "params": {
      "lr": "auto",
      "betas": [0.9, 0.95],
      "eps": 1e-8,
      "weight_decay": 0.0
    }
  },

  "scheduler": {
    "type": "WarmupDecayLR",
    "params": {
      "warmup_min_lr": 0,
      "warmup_max_lr": "auto",
      "warmup_num_steps": "auto",
      "total_num_steps": "auto"
    }
  },

  "zero_allow_untested_optimizer": true,
  "wall_clock_breakdown": false,
  "comms_logger": {
    "enabled": false
  }
}
